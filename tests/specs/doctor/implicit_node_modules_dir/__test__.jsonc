{
  "tempDir": true,
  "steps": [
    {
      // reports the implicit mode and the heuristic it derives from
      "args": "doctor",
      "output": "report.out"
    },
    {
      // --fix pins the current implicit mode explicitly
      "args": "doctor --fix",
      "output": "fix.out"
    },
    {
      "args": [
        "eval",
        "console.log(Deno.readTextFileSync('deno.json').trim())"
      ],
      "output": "deno.json.out"
    },
    {
      // a second run reports nothing (fix is idempotent)
      "args": "doctor",
      "output": "second_run.out"
    }
  ]
}
