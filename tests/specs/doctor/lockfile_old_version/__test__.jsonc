{
  "tempDir": true,
  "steps": [
    {
      "args": "doctor",
      "output": "report.out"
    },
    {
      // --fix migrates through the regular lockfile write path
      "args": "doctor --fix",
      "output": "fix.out"
    },
    {
      "args": [
        "eval",
        "console.log(Deno.readTextFileSync('deno.lock').trim())"
      ],
      "output": "deno.lock.out"
    }
  ]
}
