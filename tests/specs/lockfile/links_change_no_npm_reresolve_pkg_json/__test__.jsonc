{
  "tempDir": true,
  "envs": {
    "DENO_DIR": "$PWD/deno_dir"
  },
  "steps": [
    {
      "args": "install",
      "output": "[WILDCARD]"
    },
    {
      "args": "run -A --no-lock strip_links.ts ./deno.lock",
      "output": ""
    },
    {
      "args": "run -A --no-lock rm_packument.ts ./deno_dir/npm/localhost_4260/@denotest/esm-basic/registry.json",
      "output": ""
    },
    {
      "args": "run --cached-only main.ts",
      "output": "main.out"
    }
  ]
}
