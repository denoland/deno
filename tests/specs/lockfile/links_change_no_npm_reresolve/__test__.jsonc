{
  "tempDir": true,
  "envs": {
    "DENO_DIR": "$PWD/deno_dir"
  },
  "steps": [
    {
      // Populate the npm cache and write a lockfile that includes the `links`
      // section for the local `./linked` package.
      "args": "install",
      "output": "[WILDCARD]"
    },
    {
      // Simulate a lockfile produced by an older deno that did not track
      // workspace links, so on the next load the re-derived links differ and
      // the lockfile is flagged as changed.
      "args": "run -A --no-lock strip_links.ts ./deno.lock",
      "output": ""
    },
    {
      // Simulate a precomputed cache that has the package tarball but not its
      // registry metadata (packument). A re-resolution would need to fetch it.
      "args": "run -A --no-lock rm_packument.ts ./deno_dir/npm/localhost_4260/@denotest/esm-basic/registry.json",
      "output": ""
    },
    {
      // The links-only change must not force an npm re-resolution: the lockfile
      // already resolves every requirement, so the offline run succeeds.
      "args": "run --cached-only main.ts",
      "output": "main.out"
    }
  ]
}
