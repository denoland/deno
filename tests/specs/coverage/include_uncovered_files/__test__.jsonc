{
  "tempDir": true,
  "steps": [
    {
      "args": "test --coverage=cov add_test.ts",
      "output": "test.out",
      "exitCode": 0
    },
    {
      // Without --include only loaded files are reported; sub.ts is absent.
      "args": "coverage ./cov",
      "output": "no_include.out",
      "exitCode": 0
    },
    {
      // With --include globs, never-loaded source files are reported at 0%
      // even though the test run never loaded them: sub.ts (has a branch),
      // double.ts (arrow-in-var function), and helper.js (plain JS, no
      // transpile). comments.ts has nothing executable and is skipped.
      "args": "coverage ./cov --include=*.ts --include=*.js",
      "output": "include.out",
      "exitCode": 0
    },
    {
      // The lcov output carries the synthesized 0% records for the never-loaded
      // files.
      "args": "coverage ./cov --include=*.ts --include=*.js --lcov",
      "output": "include_lcov.out",
      "exitCode": 0
    },
    {
      // An invalid --exclude regex is a clean error, not a panic.
      "args": "coverage ./cov --include=*.ts --exclude=[",
      "output": "invalid_exclude.out",
      "exitCode": 1
    }
  ]
}
