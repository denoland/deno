{
  "tests": {
    // These are ignored in CI because type-aware linting requires the external
    // `tsgolint` binary, which is not available on CI yet (auto-download is a
    // follow-up). See README.md for how to run them manually. Protocol decoding
    // and rule resolution are covered by unit tests in
    // cli/tools/lint/tsgolint.rs.
    "floating": {
      "ignore": true,
      "args": "lint floating.ts",
      "exitCode": 1,
      "envs": {
        "DENO_UNSTABLE_TSGOLINT": "1"
      },
      "output": "[WILDCARD]no-floating-promises[WILDCARD]"
    },
    "ignore_directive": {
      "ignore": true,
      "args": "lint ignore_test.ts",
      "exitCode": 0,
      "envs": {
        "DENO_UNSTABLE_TSGOLINT": "1"
      },
      "output": "[WILDCARD]"
    }
  }
}
