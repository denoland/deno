{
  "tests": {
    "check": {
      // ignored: tsc doesn't apply sloppy-imports .d.ts resolution the way
      // deno does. https://github.com/denoland/deno/issues/36085
      "ignore": true,
      "args": "check --sloppy-imports main.ts",
      "output": "check.out"
    },
    "run": {
      "args": "run --sloppy-imports main.ts",
      "output": "run.out"
    },
    "lint": {
      "args": "lint --sloppy-imports",
      "output": "lint.out",
      "exitCode": 1
    },
    // try fixing the lint issues and then ensure deno check and run still work
    "lint_fix": {
      "tempDir": true,
      "steps": [{
        "args": "lint --sloppy-imports --fix",
        "output": "Checked 17 files\n"
      }, {
        "args": "lint --sloppy-imports",
        "output": "Checked 17 files\n"
      }, {
        "args": "check --sloppy-imports main.ts",
        "output": "check.out"
      }, {
        "args": "run --sloppy-imports main.ts",
        "output": "run.out"
      }]
    }
  }
}
