{
  "tempDir": true,
  "tests": {
    "badly_formatted": {
      "args": "fmt --unstable-component badly_formatted.mustache",
      "output": "[WILDCARD]Checked 1 file\n"
    },
    "well_formatted": {
      "args": "fmt --unstable-component --check well_formatted.mustache",
      "output": "Checked 1 file\n"
    },
    "broken": {
      "args": "fmt --unstable-component --check broken.mustache",
      "output": "Checked 1 file\n"
    }
  }
}
