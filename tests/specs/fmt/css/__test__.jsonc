{
  "tempDir": true,
  "tests": {
    "badly_formatted": {
      "args": "fmt badly_formatted.css",
      "output": "[WILDLINE]badly_formatted.css\nChecked 1 file\n"
    },
    "well_formatted": {
      "args": "fmt --check well_formatted.css",
      "output": "Checked 1 file\n"
    },
    "preserved_syntax": {
      "args": "fmt --check preserved_syntax.css",
      "output": "Checked 1 file\n"
    }
  }
}
