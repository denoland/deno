{
  "tempDir": true,
  "tests": {
    // Regression test for https://github.com/denoland/deno/issues/31924.
    // `@denotest3/gitlab-pkg` lives on a registry (port 4263) that only serves
    // metadata to npm-aware clients (those sending the npm `Accept` header) and
    // otherwise redirects to the public registry which 404s. `deno outdated`
    // must send the npm `Accept` header, the same way `deno install` does, so
    // the package shows up in the update check instead of being silently
    // dropped.
    "lists_package": {
      "steps": [
        {
          "args": "install",
          "output": "[WILDCARD]"
        },
        {
          "args": "outdated",
          "output": "outdated.out"
        }
      ]
    },
    // Documented limitation / parity with the install path: when a
    // minimum-dependency-age date is configured, the npm `Accept` header is NOT
    // sent because it requests the abbreviated packument, which omits the `time`
    // field that date filtering relies on. So `outdated` requests the full
    // packument (no `Accept` header) — exactly like `deno install` does in this
    // configuration — which the GitLab-style registry redirects, leaving the
    // metadata unfetchable. The package is then reported as skipped (with a
    // warning) rather than silently dropped. If a future change lets the full
    // packument be fetched from such a registry, this test should be updated to
    // expect the package in the table instead.
    "min_dependency_age_reports_skipped": {
      "steps": [
        {
          "args": "install",
          "output": "[WILDCARD]"
        },
        {
          "args": "outdated --minimum-dependency-age=2020-01-01T00:00:00.000Z",
          "output": "min_dep_age_skipped.out"
        }
      ]
    }
  }
}
