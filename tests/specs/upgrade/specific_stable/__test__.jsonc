// Offline upgrade flow test. DENO_TESTING_UPGRADE and the base-url override
// point the tool at the local test server (see cli/tools/upgrade.rs and
// tests/util/server/servers/mod.rs) instead of the real release hosts. The mock
// serves a placeholder, non-executable binary, so the upgrade runs through
// version resolution and the download and then fails validation (exitCode 1);
// we assert the resolved version and the mocked download URL, not a completed
// install (that end-to-end coverage lives in the real-network tests).
{
  "tempDir": true,
  "envs": {
    "DENO_TESTING_UPGRADE": "1",
    "DENO_DONT_USE_INTERNAL_BASE_UPGRADE_URL": "http://localhost:4545"
  },
  "args": "upgrade --dry-run --version 1.43.2",
  "output": "upgrade.out",
  "exitCode": 1
}
