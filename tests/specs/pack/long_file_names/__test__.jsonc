{
  "tempDir": true,
  "tests": {
    "pack_long_file_names": {
      "steps": [{
        "args": "pack",
        "output": "[WILDCARD]Packing[WILDCARD]@test/long-file-names[WILDCARD]✓[WILDCARD]test-long-file-names-1.0.0.tgz[WILDCARD]"
      }, {
        "if": "unix",
        "commandName": "bash",
        "args": [
          "-c",
          "tar -xzf test-long-file-names-1.0.0.tgz && ls package/src/kubernetes/models/_schemas/"
        ],
        "output": "long_file_names.out"
      }]
    }
  }
}
