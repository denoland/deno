{
  "tempDir": true,
  "tests": {
    "includes_assets": {
      "steps": [{
        "args": "pack --allow-dirty",
        "output": "[WILDCARD]"
      }, {
        "args": [
          "eval",
          "const tarPath = './test-publish-include-assets-1.0.0.tgz'; const file = await Deno.open(tarPath); const decoder = new DecompressionStream('gzip'); const decompressed = file.readable.pipeThrough(decoder); const reader = decompressed.getReader(); const chunks = []; while (true) { const { done, value } = await reader.read(); if (done) break; chunks.push(value); } const totalLength = chunks.reduce((acc, chunk) => acc + chunk.length, 0); const tarData = new Uint8Array(totalLength); let offset = 0; for (const chunk of chunks) { tarData.set(chunk, offset); offset += chunk.length; } const tarContent = new TextDecoder().decode(tarData); console.log('Has asset file:', tarContent.includes('package/assets/icon.svg')); console.log('Has transpiled module:', tarContent.includes('package/src/mod.js')); console.log('Has raw source duplicate:', tarContent.includes('package/src/mod.ts'));"
        ],
        "output": "Has asset file: true\nHas transpiled module: true\nHas raw source duplicate: false\n"
      }]
    }
  }
}
