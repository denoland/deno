{
  "tempDir": true,
  "tests": {
    "shebang_preserved": {
      "steps": [{
        "args": "pack",
        "output": "[WILDCARD]✓[WILDCARD]test-shebang-1.0.0.tgz[WILDCARD]"
      }, {
        "if": "unix",
        "commandName": "bash",
        "args": [
          "-c",
          "tar -xzf test-shebang-1.0.0.tgz && head -1 package/mod.js"
        ],
        "output": "#!/usr/bin/env -S deno run -A\n"
      }]
    }
  }
}
