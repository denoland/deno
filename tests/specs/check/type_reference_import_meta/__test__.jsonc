{
  "tempDir": true,
  "tests": {
    "node_modules_dir_none": {
      // ignored: with node_modules_dir "none", tsc can't resolve the ImportMeta
      // augmentation type reference. https://github.com/denoland/deno/issues/36085
      "ignore": true,
      "steps": [
        {
          "args": "run -A ./set_node_modules_dir.ts none",
          "output": ""
        },
        {
          "args": "install",
          "output": "[WILDCARD]"
        },
        {
          "args": "check ./main.ts",
          "output": "Check [WILDLINE]\n"
        }
      ]
    },
    "node_modules_dir_auto": {
      "steps": [
        {
          "args": "run -A ./set_node_modules_dir.ts auto",
          "output": ""
        },
        {
          "args": "install",
          "output": "[WILDCARD]"
        },
        {
          "args": "check ./main.ts",
          "output": "Check [WILDLINE]\n"
        }
      ]
    },
    "node_modules_dir_manual": {
      "steps": [
        {
          "args": "run -A ./set_node_modules_dir.ts auto",
          "output": ""
        },
        {
          "args": "install",
          "output": "[WILDCARD]"
        },
        {
          "args": "check ./main.ts",
          "output": "Check [WILDLINE]\n"
        }
      ]
    }
  }
}
