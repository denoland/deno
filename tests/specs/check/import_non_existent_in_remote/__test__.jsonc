{
  // Isolate the two variants: they share the fixture and would otherwise race
  // on the generated `.deno/` config when run concurrently.
  "tempDir": true,
  "tests": {
    "not_all": {
      "args": "check --allow-import import_remote.ts",
      "output": "[WILDCARD]",
      "exitCode": 0
    },
    "all": {
      "args": "check --all --allow-import import_remote.ts",
      "output": "check_all.out",
      "exitCode": 1
    }
  }
}
