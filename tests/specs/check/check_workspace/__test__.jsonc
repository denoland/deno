{
  "ignore": true,
  "//": "Disabled during the TypeScript un-fork: this asserts per-scope global availability (window vs worker), but the @types/node deferral markers (onmessage/onabort/ReportingObserver) intentionally make onmessage resolve in the window scope, so the test needs a redesigned discriminator. Re-enabled by a markers follow-up.",
  "tests": {
    "discover": {
      "args": "check main.ts member/mod.ts",
      "output": "check_discover.out",
      "exitCode": 1
    },
    "config_flag": {
      "args": "check --config deno.json main.ts member/mod.ts",
      "output": "check_config_flag.out",
      "exitCode": 1
    }
  }
}
