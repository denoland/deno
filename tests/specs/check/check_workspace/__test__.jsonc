{
  // ignored (both): per-workspace-member `compilerOptions.lib` isn't honored by
  // the generated single-project config, so a member's lib-specific error (the
  // `alert` TS2304) no longer surfaces. Matches the sibling `workspace` ignore.
  // https://github.com/denoland/deno/issues/36085
  "tests": {
    "discover": {
      "ignore": true,
      "args": "check main.ts member/mod.ts",
      "output": "check_discover.out",
      "exitCode": 1
    },
    "config_flag": {
      "ignore": true,
      "args": "check --config deno.json main.ts member/mod.ts",
      "output": "check_config_flag.out",
      "exitCode": 1
    }
  }
}
