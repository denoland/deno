{
  // ignored: deno.ns lib is always resolvable now, so the "Cannot find lib
  // definition for 'deno.ns'" error no longer fires.
  // https://github.com/denoland/deno/issues/36085
  "ignore": true,
  "steps": [
    {
      "args": "check main.ts",
      "output": "main.out",
      "exitCode": 1
    },
    {
      "args": "check no_default_lib.ts",
      "output": "no_default_lib.out",
      "exitCode": 1
    }
  ]
}
