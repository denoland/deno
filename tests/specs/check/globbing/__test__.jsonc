{
  "tests": {
    "star": {
      "args": "check *.ts",
      "output": "Check [WILDCARD]main.ts\nChecked 1 file\n",
      "exitCode": 0
    },
    "star_not_found": {
      "args": "check *.js",
      "output": "Warning No matching files found.\nChecked 0 files\n",
      "exitCode": 0
    },
    "glob_star": {
      "args": "check **/*.ts",
      "output": "Check [WILDCARD]main.ts\nTS2322[WILDCARD]",
      "exitCode": 1
    },
    "sub_dir": {
      "args": "check sub_dir",
      "output": "Check [WILDCARD]main.ts\nTS2322[WILDCARD]",
      "exitCode": 1
    }
  }
}
