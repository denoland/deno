{
  // TODO(bartlomieju): re-enable once Deno's type checker stops auto-loading
  // lib.dom.d.ts when @types/node is resolved. The deduplication in
  // libs/resolver/deno_json.rs strips the generated `.deno/tsconfig.json`
  // from the extends chain (so its `types: ["deno"]` directive doesn't
  // reach Deno's checker), and the @types/deno relocation to .deno/types/
  // keeps it out of node_modules-based auto-discovery, but main.ts still
  // forces `<reference types="@types/node" />`, which pulls in lib.dom
  // and collides with lib.deno.shared_globals. See
  // tests/specs/check/npm_compat_tsconfig_extends_filter for a focused
  // test of the extends filter that does not require resolving this.
  "ignore": true,
  "tempDir": true,
  "tests": {
    "node_modules_dir_none": {
      "steps": [
        {
          "args": "run -A ./set_node_modules_dir.ts none",
          "output": ""
        },
        {
          "args": "install",
          "output": "[WILDCARD]"
        },
        {
          "args": "check --all ./main.ts",
          "output": "Check [WILDCARD]main.ts\n"
        }
      ]
    },
    "node_modules_dir_auto": {
      "steps": [
        {
          "args": "run -A ./set_node_modules_dir.ts auto",
          "output": ""
        },
        {
          "args": "install",
          "output": "[WILDCARD]"
        },
        {
          "args": "check --all ./main.ts",
          "output": "Check [WILDCARD]main.ts\n"
        }
      ]
    },
    "node_modules_dir_manual": {
      "steps": [
        {
          "args": "run -A ./set_node_modules_dir.ts auto",
          "output": ""
        },
        {
          "args": "install",
          "output": "[WILDCARD]"
        },
        {
          "args": "check --all ./main.ts",
          "output": "Check [WILDCARD]main.ts\n"
        }
      ]
    }
  }
}
