{
  "tempDir": true,
  // Enabling the cache requires a resolvable app-data dir; redirect it into
  // the temp dir to keep the run hermetic.
  "envs": {
    "HOME": "$PWD",
    "USERPROFILE": "$PWD",
    "XDG_DATA_HOME": "$PWD/data",
    "LOCALAPPDATA": "$PWD/data"
  },
  "steps": [
    {
      "if": "unix",
      "args": "compile -A --output out main.ts",
      "output": "[WILDCARD]"
    },
    {
      "if": "unix",
      "commandName": "./out",
      "args": [],
      "output": "cached body\n"
    },
    {
      "if": "windows",
      "args": "compile -A --output out.exe main.ts",
      "output": "[WILDCARD]"
    },
    {
      "if": "windows",
      "commandName": "./out.exe",
      "args": [],
      "output": "cached body\n"
    }
  ]
}
