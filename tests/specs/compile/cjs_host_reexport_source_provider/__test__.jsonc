{
  "tempDir": true,
  "steps": [{
    "if": "unix",
    "args": "compile --no-prompt --allow-read --output main-reexport main.ts",
    "output": "[WILDCARD]"
  }, {
    "if": "unix",
    "args": "compile --no-prompt --allow-read=allowed --output main-denied main.ts",
    "output": "[WILDCARD]"
  }, {
    "if": "unix",
    "args": "run -A setup.ts",
    "output": ""
  }, {
    "if": "unix",
    "commandName": "./main-reexport",
    "args": ["reexport"],
    "output": "from-inner\n"
  }, {
    "if": "unix",
    "commandName": "./main-denied",
    "args": ["denied"],
    "output": "blocked\n"
  }, {
    "if": "windows",
    "args": "compile --no-prompt --allow-read --output main-reexport.exe main.ts",
    "output": "[WILDCARD]"
  }, {
    "if": "windows",
    "args": "compile --no-prompt --allow-read=allowed --output main-denied.exe main.ts",
    "output": "[WILDCARD]"
  }, {
    "if": "windows",
    "args": "run -A setup.ts",
    "output": ""
  }, {
    "if": "windows",
    "commandName": "./main-reexport.exe",
    "args": ["reexport"],
    "output": "from-inner\n"
  }, {
    "if": "windows",
    "commandName": "./main-denied.exe",
    "args": ["denied"],
    "output": "blocked\n"
  }]
}
