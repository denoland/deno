{
  "tempDir": true,
  // keep the vfs output in a single folder
  "canonicalizedTempDir": true,
  "steps": [{
    "if": "unix",
    "args": "compile --allow-import --output main main.ts",
    "output": "compile.out"
  }, {
    "if": "unix",
    "commandName": "./main",
    "args": [],
    "output": "run.out"
  }, {
    "if": "windows",
    "args": "compile --allow-import --output main.exe main.ts",
    "output": "compile.out"
  }, {
    "if": "windows",
    "commandName": "./main.exe",
    "args": [],
    "output": "run.out"
  }]
}
