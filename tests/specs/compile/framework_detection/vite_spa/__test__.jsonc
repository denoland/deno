{
  "tempDir": true,
  "tests": {
    // A plain Vite SPA (vite.config.ts, no server.{js,ts,mjs}) has no server
    // entrypoint, so framework detection generates a static-file-server
    // entrypoint that imports `@std/http` and serves the built `dist/`. This
    // guards that the whole SPA path — detect Vite, run the build task, resolve
    // the generated entrypoint's `@std/http` import, include `dist/`, bundle —
    // compiles into a binary. The `@std/http` import is remapped to a local
    // stub in `deno.json` so the test stays hermetic.
    "vite_spa": {
      "steps": [{
        "if": "unix",
        "args": "compile -A --output main .",
        "output": "compile.out"
      }, {
        "if": "windows",
        "args": "compile -A --output main.exe .",
        "output": "compile.out"
      }]
    }
  }
}
