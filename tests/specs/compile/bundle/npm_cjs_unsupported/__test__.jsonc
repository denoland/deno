{
  // CJS npm packages with a default export are inlined into the bundle, but
  // their default-export interop is not yet correct: the default import
  // resolves to a non-callable value at runtime. This is a known limitation;
  // the test locks in the current failure mode and should be removed once CJS
  // default-export interop works in --bundle.
  "tempDir": true,
  "steps": [{
    "args": "install",
    "output": "[WILDCARD]"
  }, {
    "if": "unix",
    "args": "compile --bundle --no-check --output main main.ts",
    "output": "[WILDCARD]"
  }, {
    "if": "unix",
    "commandName": "./main",
    "args": [],
    "output": "run.out",
    "exitCode": 1
  }, {
    "if": "windows",
    "args": "compile --bundle --no-check --output main.exe main.ts",
    "output": "[WILDCARD]"
  }, {
    "if": "windows",
    "commandName": "./main.exe",
    "args": [],
    "output": "run.out",
    "exitCode": 1
  }]
}
