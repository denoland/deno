{
  // CJS npm packages are currently externalized by esbuild as a runtime
  // require() against node_modules, which --bundle intentionally strips. This
  // is a known limitation; the test locks in the current failure mode and
  // should be removed once CJS packages are inlined into the bundle.
  "tempDir": true,
  "steps": [{
    "args": "install",
    "output": "[WILDCARD]"
  }, {
    "if": "unix",
    "args": "compile --bundle --no-check --output main main.ts",
    "output": "[WILDCARD]"
  }, {
    "if": "unix",
    "commandName": "./main",
    "args": [],
    "output": "run.out",
    "exitCode": 1
  }, {
    "if": "windows",
    "args": "compile --bundle --no-check --output main.exe main.ts",
    "output": "[WILDCARD]"
  }, {
    "if": "windows",
    "commandName": "./main.exe",
    "args": [],
    "output": "run.out",
    "exitCode": 1
  }]
}
