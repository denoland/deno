{
  "tempDir": true,
  "tests": {
    "invalid_fd": {
      "args": "run -A invalid_fd.ts",
      "output": "invalid_fd.out"
    },
    "open_fd": {
      "if": "unix",
      "args": "run -A --unstable-ffi open_fd.ts",
      "output": "open_fd.out"
    },
    "open_fd_windows": {
      "if": "windows",
      "args": "run -A --unstable-ffi open_fd_windows.ts",
      "output": "open_fd_windows.out"
    }
  }
}
