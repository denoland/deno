{
  "tests": {
    "virtual_module_import": {
      "args": "run -A main.mjs",
      "output": "main.out"
    },
    "fallthrough": {
      "args": "run -A test_fallthrough.mjs",
      "output": "test_fallthrough.out"
    },
    "default_resolve": {
      "cwd": "default_resolve",
      "args": "run -A test.mjs",
      "output": "default_resolve/test.out"
    },
    "worker": {
      "cwd": "worker",
      "args": "run -A main.mjs",
      "output": "worker/main.out"
    },
    "preload_main": {
      "cwd": "preload_main",
      "args": "run -A --import=./hook.mjs main.mjs",
      "output": "preload_main/main.out"
    },
    "redirect": {
      "cwd": "redirect",
      "args": "run -A main.mjs",
      "output": "redirect/main.out"
    },
    "resolve_cache_bust": {
      "cwd": "resolve_cache_bust",
      "args": "run -A main.mjs",
      "output": "resolve_cache_bust/main.out"
    }
  }
}
