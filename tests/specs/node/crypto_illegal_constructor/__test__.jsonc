// Regression test: `new CryptoKey()` / `new SubtleCrypto()` / `new Crypto()`
// throw a `TypeError` with `code: 'ERR_ILLEGAL_CONSTRUCTOR'`, matching
// Node so that consumers using `assert.throws(fn, { code: '...' })` --
// the shape upstream `parallel/test-webcrypto-constructors.js` uses --
// pass.
{
  "tests": {
    "illegal_constructor": {
      "args": "run -A main.mjs",
      "output": "main.out"
    }
  }
}
