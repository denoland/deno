{
  "tests": {
    "resource_limits_passed": {
      "args": "run --allow-read main.mjs",
      "output": "main.out"
    },
    "resource_limits_default": {
      "args": "run --allow-read default_main.mjs",
      "output": "default_main.out"
    },
    "resource_limits_default_stack_size": {
      "args": "run --allow-read --v8-flags=--stack-size=3072 stack_size_default_main.mjs",
      "output": "stack_size_default.out"
    },
    "resource_limits_oom": {
      "args": "run --allow-read oom_main.mjs",
      "output": "oom_main.out",
      "exitCode": 0
    },
    "resource_limits_overflow": {
      "args": "run overflow_main.mjs",
      "output": "overflow_main.out"
    }
  }
}
