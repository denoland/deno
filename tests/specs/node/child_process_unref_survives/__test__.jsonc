{
  "tempDir": true,
  "tests": {
    // On Windows, non-detached children are assigned to a global job object with
    // JOB_OBJECT_LIMIT_KILL_ON_JOB_CLOSE, so they are always terminated when the
    // parent exits — regardless of unref(). This is a Windows OS-level behaviour
    // that cannot be changed after the child is spawned.
    "unref_child_survives_parent_exit": {
      "if": "unix",
      "steps": [
        {
          "args": "run --allow-all parent.ts",
          "output": ""
        },
        {
          "args": "run --allow-read verify.ts",
          "output": "OK: child process survived parent exit\n"
        }
      ]
    }
  }
}
