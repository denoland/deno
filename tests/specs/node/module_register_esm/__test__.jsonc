{
  "tests": {
    "basic_hooks": {
      "args": "run -A main.mjs",
      "output": "main.out"
    },
    "initialize_with_port": {
      "args": "run -A test_initialize.mjs",
      "output": "test_initialize.out"
    },
    "chaining": {
      "args": "run -A test_chaining.mjs",
      "output": "test_chaining.out"
    },
    "ordering_sync_before_async": {
      "args": "run -A test_ordering.mjs",
      "output": "test_ordering.out"
    },
    "custom_filetype_yaml": {
      "args": "run -A test_yaml.mjs",
      "output": "test_yaml.out"
    },
    "node_builtin_import_after_register": {
      "args": "run -A test_node_builtin_import.mjs",
      "output": "test_node_builtin_import.out"
    },
    "passthrough_hook_preserves_import_map": {
      "cwd": "passthrough_imports",
      "args": "run -A main.mjs",
      "output": "passthrough_imports/main.out"
    },
    "passthrough_hook_preserves_npm_intra_package_referrer": {
      "cwd": "passthrough_npm",
      "args": "run -A main.mjs",
      "output": "passthrough_npm/main.out"
    }
  }
}
