// Pins the known limitation of the hoisted linker's per-member `node_modules`:
// when two workspace members directly depend on different versions of the same
// package, the higher version is hoisted to the workspace root and the lower
// one is not placed in the hoisted layout, so the member declaring the lower
// version does not get it linked into its own `node_modules`. When the
// follow-up fix lands, the marked assertion in check.ts should flip.
//
// https://github.com/denoland/deno/pull/34970
{
  "tempDir": true,
  "tests": {
    "hoisted": {
      "steps": [
        {
          "args": "install --node-modules-dir=manual --node-modules-linker=hoisted",
          "output": "[WILDCARD]"
        },
        {
          "args": "run --allow-read check.ts",
          "output": "check.out"
        }
      ]
    }
  }
}
