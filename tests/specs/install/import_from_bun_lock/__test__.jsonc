{
  "tempDir": true,
  "steps": [
    {
      // No deno.lock, package-lock.json, or pnpm-lock.yaml — fall back to
      // translating bun's text lockfile.
      "args": "install",
      "output": "install.out"
    },
    {
      "args": [
        "eval",
        "console.log(Deno.readTextFileSync('deno.lock').trim())"
      ],
      "output": "deno.lock.out"
    },
    {
      "args": "run --cached-only main.js",
      "output": "3\n"
    }
  ]
}
