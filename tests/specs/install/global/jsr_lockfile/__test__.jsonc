{
  "tempDir": true,
  "steps": [{
    "if": "unix",
    "args": "install -g --root ./bins jsr:@denotest/echo-lockfile",
    "output": "install.out"
  }, {
    // Verify the lockfile was placed in the config directory
    "if": "unix",
    "args": "eval console.log(Deno.readTextFileSync('./bins/bin/.echo-lockfile/deno.lock'))",
    "output": "lockfile.out"
  }, {
    "if": "unix",
    "commandName": "./bins/bin/echo-lockfile",
    "args": ["hello", "there"],
    "output": "run.out",
    "exitCode": 0
  }, {
    "if": "windows",
    "args": "install -g --root ./bins jsr:@denotest/echo-lockfile",
    "output": "install.out"
  }, {
    "if": "windows",
    "args": "eval console.log(Deno.readTextFileSync('./bins/bin/.echo-lockfile/deno.lock'))",
    "output": "lockfile.out"
  }, {
    "if": "windows",
    "commandName": "./bins/bin/echo-lockfile.cmd",
    "args": ["hello", "there"],
    "output": "run.out",
    "exitCode": 0
  }]
}
