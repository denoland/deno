{
  "tempDir": true,
  "steps": [{
    "if": "unix",
    "args": "install -g --root ./bins jsr:@denotest/echo-lockfile-bad-tarball",
    "output": "install.out"
  }, {
    // Verify the lockfile does NOT contain the evil tarball URL
    "if": "unix",
    "args": [
      "eval",
      "const content = Deno.readTextFileSync('./bins/bin/.echo-lockfile-bad-tarball/deno.lock'); console.log(content.includes('evil.example.com') ? 'bad tarball found' : 'clean lockfile');"
    ],
    "output": "no_lockfile.out"
  }, {
    "if": "windows",
    "args": "install -g --root ./bins jsr:@denotest/echo-lockfile-bad-tarball",
    "output": "install.out"
  }, {
    "if": "windows",
    "args": [
      "eval",
      "const content = Deno.readTextFileSync('./bins/bin/.echo-lockfile-bad-tarball/deno.lock'); console.log(content.includes('evil.example.com') ? 'bad tarball found' : 'clean lockfile');"
    ],
    "output": "no_lockfile.out"
  }]
}
