{
  "tempDir": true,
  "steps": [{
    "if": "unix",
    "args": "install -g --root ./bins --config deno.json --name my-cli main.ts",
    "output": "install.out"
  }, {
    "if": "unix",
    "commandName": "./bins/bin/my-cli",
    "args": [],
    "output": "run.out",
    "exitCode": 0
  }, {
    "if": "windows",
    "args": "install -g --root ./bins --config deno.json --name my-cli main.ts",
    "output": "install.out"
  }, {
    "if": "windows",
    "commandName": "./bins/bin/my-cli.cmd",
    "args": [],
    "output": "run.out",
    "exitCode": 0
  }]
}
