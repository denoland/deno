{
  // Skipped on windows-aarch64: flakes intermittently (`flakyCount: 4`),
  // independently reproduced across orthogonal PRs. Tracked in #33976.
  "if": "notWindowsArm",
  "tempDir": true,
  "steps": [{
    "if": "unix",
    "args": "install -g --allow-scripts --root ./bins --name lifecycle-scripts-simple npm:@denotest/lifecycle-scripts-simple",
    "output": "install.out"
  }, {
    "if": "unix",
    "commandName": "./bins/bin/lifecycle-scripts-simple",
    "args": [],
    "output": "run.out",
    "exitCode": 0
  }, {
    "if": "windows",
    "args": "install -g --allow-scripts --root ./bins --name lifecycle-scripts-simple npm:@denotest/lifecycle-scripts-simple",
    "output": "install.out"
  }, {
    "if": "windows",
    "commandName": "./bins/bin/lifecycle-scripts-simple.cmd",
    "args": [],
    "output": "run.out",
    "exitCode": 0
  }]
}
