{
  "tempDir": true,
  "steps": [{
    "args": "install -g --root ./bins jsr:@denotest/echo-lockfile-pinned",
    "output": "install.out"
  }, {
    "args": [
      "eval",
      "const lock = JSON.parse(Deno.readTextFileSync('./bins/bin/.echo-lockfile-pinned/deno.lock')); console.log(lock.specifiers['jsr:@denotest/add@0.2']); console.log(lock.workspace.dependencies.includes('jsr:@denotest/add@0.2'));"
    ],
    "output": "lockfile.out"
  }]
}
