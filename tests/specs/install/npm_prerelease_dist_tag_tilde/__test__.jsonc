{
  "tempDir": true,
  "steps": [
    {
      "args": "install -D npm:@denotest/insiders-tag@~0.0.0-insiders.fc3a063",
      "output": "install.out"
    },
    {
      "args": "eval globalThis.console.log(Deno.readTextFileSync('package.json'))",
      "output": "package_json.out"
    },
    {
      "args": "eval globalThis.console.log(Deno.readTextFileSync('deno.lock'))",
      "output": "lock.out"
    }
  ]
}
