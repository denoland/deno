{
  "tempDir": true,
  "steps": [
    {
      // No deno.lock or package-lock.json — `deno install` should seed
      // deno.lock from pnpm-lock.yaml instead.
      "args": "install",
      "output": "install.out"
    },
    {
      "args": [
        "eval",
        "console.log(Deno.readTextFileSync('deno.lock').trim())"
      ],
      "output": "deno.lock.out"
    },
    {
      "args": "run --cached-only main.js",
      "output": "3\n"
    }
  ]
}
