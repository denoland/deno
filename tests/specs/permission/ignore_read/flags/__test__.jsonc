{
  "tests": {
    "all": {
      "args": "run --ignore-read main.ts",
      "output": "true\ntrue\n"
    },
    "some": {
      // data.txt is explicitly denied so it stays NotCapable (false) rather
      // than becoming readable under the default cwd read confinement; this
      // keeps the test's contrast between an ignored path (NotFound, true) and
      // a non-ignored, non-readable path (NotCapable, false).
      "args": "run --ignore-read=deno.json --deny-read=data.txt main.ts",
      "output": "true\nfalse\n"
    },
    "some_allow_env": {
      "args": "run --ignore-read=deno.json --allow-read main.ts",
      "output": "true\nloaded\n"
    },
    "deny_env": {
      "args": "run --deny-read --ignore-read=deno.json main.ts",
      "output": "true\nfalse\n"
    }
  }
}
