{
  // Regression test for https://github.com/denoland/deno/issues/17679 and
  // https://github.com/denoland/deno/issues/18478 — npm packages whose
  // transitive dependencies use git or git+https specifiers (including the
  // github:/gitlab:/bitbucket:/gist: shorthands) should not cause a
  // resolution error. The git dep itself is silently skipped, mirroring how
  // transitive file: / link: dependencies are handled.
  "args": "run main.ts",
  "output": "main.out"
}
