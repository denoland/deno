{
  // NOTE: `all` and `local` currently produce identical output because the only
  // difference was the package's own index.d.ts errors (TS2506), which
  // skipLibCheck:true suppresses for both. The --all/local distinction returns
  // once skipLibCheck flips to false. https://github.com/denoland/deno/issues/36094
  "tests": {
    "all": {
      "args": "check --all main.ts",
      "output": "main_all.out",
      "exitCode": 1
    },
    "local": {
      "args": "check main.ts",
      "output": "main_local.out",
      "exitCode": 1
    }
  }
}
