{
  "tempDir": true,
  "tests": {
    // Regression test for https://github.com/denoland/deno/issues/24916.
    // A package whose `postinstall` runs `node --require ./helper.cjs main.cjs`
    // and `node -p "..."` must succeed even when there is no `node` binary on
    // `PATH` (the invocations are translated to Deno). Clearing `PATH` ensures
    // the new translation is exercised rather than a real `node` fallback.
    "node_require_and_print_postinstall_without_node_binary": {
      "steps": [
        {
          "envs": {
            "PATH": ""
          },
          "args": "cache --allow-scripts main.js",
          "output": "cache.out"
        },
        {
          // `node --require ./helper.cjs main.cjs`: "object" confirms the
          // `--require` preload actually ran (it would be "undefined" if the
          // `--require` flag had been dropped during translation).
          "args": [
            "eval",
            "console.log(Deno.readTextFileSync('./node_require_ran.txt'))"
          ],
          "output": "require object\n"
        },
        {
          // `node -p "..."`: confirms the `-p`/print path ran under Deno.
          "args": [
            "eval",
            "console.log(Deno.readTextFileSync('./node_print_ran.txt'))"
          ],
          "output": "print object\n"
        }
      ]
    }
  }
}
