{
  // TODO(bartlomieju): re-enable once NativePipe registers a Deno resource
  // for HTTP use cases. Playwright's pipe transport works but the browser
  // process exits before CDP handshake completes.
  "ignore": true,
  "envs": {
    "PLAYWRIGHT_BROWSERS_PATH": "../../../../.ms-playwright"
  },
  "steps": [{
    "args": "run -A npm:playwright install chromium",
    "output": "[WILDCARD]"
  }, {
    "args": "run -A main.ts",
    "flaky": true,
    "output": "chromium launched\n"
  }]
}
