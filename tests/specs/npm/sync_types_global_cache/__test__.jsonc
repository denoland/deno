{
  // `deno sync-types` in global-cache mode (nodeModulesDir: "none") should
  // generate per-package referenced tsconfig projects under `.deno/npm/`
  // without materializing a `node_modules` tree.
  "tempDir": true,
  "steps": [
    {
      "args": "sync-types",
      "output": "sync-types.out"
    },
    {
      "args": "run --allow-read check.ts",
      "output": "check.out"
    }
  ]
}
