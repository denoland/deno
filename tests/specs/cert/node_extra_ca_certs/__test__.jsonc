{
  "tests": {
    "fetch": {
      "envs": { "NODE_EXTRA_CA_CERTS": "../../../testdata/tls/RootCA.pem" },
      "args": "eval --quiet fetch('https://localhost:5545/cert/cafile_ts_fetch.ts.out').then(r=>r.text()).then(t=>console.log(t.trimEnd()))",
      "flaky": true,
      "output": "[WILDCARD]Hello\n"
    },
    "missing": {
      "envs": { "NODE_EXTRA_CA_CERTS": "./non_existent_cert.pem" },
      "args": "eval --quiet --cert ../../../testdata/tls/RootCA.pem fetch('https://localhost:5545/cert/cafile_ts_fetch.ts.out').then(r=>r.text()).then(t=>console.log(t.trimEnd()))",
      "flaky": true,
      "output": "[WILDCARD]Hello\n"
    }
  }
}
