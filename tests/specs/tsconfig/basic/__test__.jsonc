{
  "tempDir": true,
  "tests": {
    "generates_tsconfig": {
      "steps": [
        {
          "args": "tsconfig",
          "output": "generate.out"
        },
        {
          "args": "run --allow-read verify.ts",
          "output": "verify.out"
        }
      ]
    },
    "idempotent": {
      "steps": [
        {
          "args": "tsconfig",
          "output": "[WILDCARD]Generated[WILDCARD]"
        },
        {
          "args": "tsconfig",
          "output": "[WILDCARD]Generated[WILDCARD]deno.tsconfig.json\n[WILDCARD]Unchanged[WILDCARD]tsconfig.json[WILDCARD]\n"
        }
      ]
    }
  }
}
