{
  "compilerOptions": {
    "strict": true,
    "noImplicitOverride": true,
    "allowJs": true,
    "checkJs": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "allowImportingTsExtensions": true,
    "lib": [
      "esnext"
    ],
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "paths": {
      "npm:chalk": [
        "./node_modules/chalk"
      ],
      "npm:chalk/*": [
        "./node_modules/chalk/*"
      ]
    }
  },
  "include": [
    "./**/*"
  ],
  "files": [
    ".deno/types/deno.d.ts"
  ],
  "exclude": [
    "./**/node_modules",
    "./.deno"
  ]
}
