{
  "tempDir": true,
  "tests": {
    "prefers_package_json_from_config": {
      // With "preferPackageJson": true in deno.json, `deno add` (no flag)
      // routes all packages into package.json.
      "steps": [
        {
          "args": "add npm:@denotest/esm-basic jsr:@denotest/add",
          "output": "add.out"
        },
        {
          "args": [
            "eval",
            "console.log(Deno.readTextFileSync('package.json').trim())"
          ],
          "output": "package.json.out"
        },
        {
          "args": [
            "eval",
            "console.log(Deno.readTextFileSync('deno.json').trim())"
          ],
          "output": "deno.json.out"
        }
      ]
    },
    "creates_package_json_if_missing": {
      // With "preferPackageJson": true but no package.json, one is created.
      "steps": [
        {
          "args": [
            "eval",
            "Deno.removeSync('package.json')"
          ],
          "output": ""
        },
        {
          "args": "add npm:@denotest/esm-basic",
          "output": "add_create.out"
        },
        {
          "args": [
            "eval",
            "console.log(Deno.readTextFileSync('package.json').trim())"
          ],
          "output": "created_package.json.out"
        }
      ]
    }
  }
}
