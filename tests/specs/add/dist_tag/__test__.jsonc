{
  "tempDir": true,
  "tests": {
    "npm_latest": {
      "steps": [
        {
          "args": "add npm:ajv@latest",
          "output": "add.out"
        }
      ]
    },
    "jsr_latest": {
      "steps": [
        {
          "args": "add jsr:@denotest/add@latest",
          "output": "add_jsr.out"
        }
      ]
    },
    "jsr_unsupported_tag": {
      "steps": [
        {
          "args": "add jsr:@denotest/add@beta",
          "output": "add_jsr_unsupported_tag.out",
          "exitCode": 1
        }
      ]
    }
  }
}
