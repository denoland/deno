{
  "tests": {
    "ignored_leak_not_attributed_to_later_test": {
      "args": "test --allow-net=127.0.0.1 --sanitize-ops --sanitize-resources --trace-leaks main.ts",
      "output": "main.out"
    },
    "ignored_timer_firing_during_later_test": {
      "args": "test --sanitize-ops --sanitize-resources --trace-leaks issue_22927.ts",
      "output": "issue_22927.out"
    },
    "failed_ignored_test_leak_not_attributed_to_later_test": {
      "args": "test --sanitize-ops --sanitize-resources --trace-leaks failed_ignored_test_leak.ts",
      "exitCode": 1,
      "output": "failed_ignored_test_leak.out"
    },
    "genuine_leaks_still_detected": {
      "args": "test --allow-net=127.0.0.1 --sanitize-ops --sanitize-resources --trace-leaks genuine_resource_and_op_leak.ts",
      "exitCode": 1,
      "output": "genuine_resource_and_op_leak.out"
    }
  }
}
