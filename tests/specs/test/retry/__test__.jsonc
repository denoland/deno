{
  "tempDir": true,
  "tests": {
    "retry_pass": {
      "args": "test --quiet retry_pass.ts",
      "exitCode": 0,
      "output": "retry_pass.out"
    },
    "retry_exhausted": {
      "args": "test --quiet retry_exhausted.ts",
      "exitCode": 1,
      "output": "retry_exhausted.out"
    },
    "repeats_pass": {
      "args": "test --quiet repeats_pass.ts",
      "exitCode": 0,
      "output": "repeats_pass.out"
    },
    "repeats_fail": {
      "args": "test --quiet repeats_fail.ts",
      "exitCode": 1,
      "output": "repeats_fail.out"
    },
    "retry_steps": {
      "args": "test --quiet retry_steps.ts",
      "exitCode": 0,
      "output": "retry_steps.out"
    },
    "repeats_steps": {
      "args": "test --quiet repeats_steps.ts",
      "exitCode": 0,
      "output": "repeats_steps.out"
    },
    "cli_retry_flag": {
      "args": "test --quiet --retry=2 cli_retry_flag.ts",
      "exitCode": 0,
      "output": "cli_retry_flag.out"
    },
    "repeats_flag": {
      "args": "test --quiet --repeats=2 repeats_flag.ts",
      "exitCode": 1,
      "output": "repeats_flag.out"
    },
    "flag_override": {
      "args": "test --quiet --retry=5 flag_override.ts",
      "exitCode": 1,
      "output": "flag_override.out"
    },
    "flag_optout": {
      "args": "test --quiet --retry=5 flag_optout.ts",
      "exitCode": 1,
      "output": "flag_optout.out"
    },
    "retry_repeats": {
      "args": "test --quiet retry_repeats.ts",
      "exitCode": 0,
      "output": "retry_repeats.out"
    },
    "validation_negative": {
      "args": "test --quiet validation_negative.ts",
      "exitCode": 1,
      "output": "validation_negative.out"
    },
    "validation_repeats_negative": {
      "args": "test --quiet validation_repeats_negative.ts",
      "exitCode": 1,
      "output": "validation_repeats_negative.out"
    }
  }
}
