{
  "tests": {
    "permissions": {
      "args": "test --doc --allow-read --allow-env --reload main.ts",
      "exitCode": 1,
      "output": "main.out"
    },
    "invalid_shebang": {
      "args": "test --doc --reload invalid.ts",
      "exitCode": 1,
      "output": "invalid.out"
    },
    "deny_flag_warns": {
      "args": "test --doc --allow-read --reload deny.ts",
      "exitCode": 0,
      "output": "deny.out"
    }
  }
}
