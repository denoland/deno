{
  "tests": {
    "permissions": {
      "args": "test --doc --allow-read --allow-env --reload main.ts",
      "exitCode": 1,
      "output": "main.out"
    },
    "invalid_shebang": {
      "args": "test --doc --reload invalid.ts",
      "exitCode": 1,
      "output": "invalid.out"
    },
    "bare_deny": {
      "args": "test --doc --allow-read --allow-env --reload deny.ts",
      "exitCode": 1,
      "output": "deny.out"
    },
    "scoped_deny": {
      "args": "test --doc --allow-read --reload scoped.ts",
      "exitCode": 1,
      "output": "scoped.out"
    }
  }
}
