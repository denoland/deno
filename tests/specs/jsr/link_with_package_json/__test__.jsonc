{
  // Regression test for https://github.com/denoland/deno/issues/29835
  // A linked package that has a deno.json is a Deno/JSR link. Some packages
  // also ship a package.json only for other runtimes (e.g. Bun), and that
  // incidental package.json must not make Deno treat the link as an npm
  // package, which previously failed with "Linking npm packages requires
  // using a node_modules directory" unless "nodeModulesDir" was set.
  "tempDir": true,
  "args": "run main.ts",
  "output": "main.out"
}
