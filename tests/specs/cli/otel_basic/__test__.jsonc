{
  "tests": {
    "basic": {
      "args": "run -A main.ts basic.ts",
      "output": "basic.out"
    },
    "basic_vsock": {
      "if": "linux",
      "args": "run -A --unstable-vsock main.ts basic.ts",
      "envs": {
        "OTEL_DENO_VSOCK": "1:4317"
      },
      "output": "basic.out"
    },
    "natural_exit": {
      "args": "run -A main.ts natural_exit.ts",
      "output": "natural_exit.out"
    },
    "deno_dot_exit": {
      "args": "run -A main.ts deno_dot_exit.ts",
      "output": "deno_dot_exit.out"
    },
    "uncaught": {
      "args": "run -A main.ts uncaught.ts",
      "output": "uncaught.out"
    },
    "metric": {
      "envs": {
        "OTEL_METRIC_EXPORT_INTERVAL": "1000"
      },
      "args": "run -A main.ts metric.ts",
      "output": "metric.out"
    },
    "metric_zero_interval": {
      "envs": {
        "OTEL_METRIC_EXPORT_INTERVAL": "0"
      },
      "args": "run -A main.ts metric_zero_interval.ts",
      "output": "metric_zero_interval.out"
    },
    "fetch": {
      "args": "run -A main.ts fetch.ts",
      "output": "fetch.out"
    },
    "http_metric": {
      "envs": {
        "OTEL_METRIC_EXPORT_INTERVAL": "1000"
      },
      "args": "run -A main.ts http_metric.ts",
      "output": "http_metric.out"
    },
    "http_propagators": {
      "args": "run -A main.ts http_propagators.ts",
      "output": "http_propagators.out"
    },
    "node_http_metric": {
      "envs": {
        "OTEL_METRIC_EXPORT_INTERVAL": "1000",
        "OTEL_EXPORTER_OTLP_METRICS_TEMPORALITY_PREFERENCE": "cumulative"
      },
      "args": "run -A main.ts node_http_metric.ts",
      "output": "node_http_metric.out"
    },
    "links": {
      "args": "run -A main.ts links.ts",
      "output": "links.out"
    },
    "start_active_span": {
      "args": "run -A main.ts start_active_span.ts",
      "output": "start_active_span.out"
    },
    "node_http_request": {
      "args": "run -A main.ts node_http_request.ts",
      "output": "node_http_request.out"
    },
    "http2": {
      "args": "run -A main.ts http2.ts",
      "output": "http2.out"
    },
    "events": {
      "args": "run -A main.ts events.ts",
      "output": "events.out"
    },
    "metric_temporality_delta": {
      "envs": {
        "OTEL_METRIC_EXPORT_INTERVAL": "1000",
        "OTEL_EXPORTER_OTLP_METRICS_TEMPORALITY_PREFERENCE": "delta"
      },
      "args": "run -A main.ts metric_temporality.ts",
      "output": "metric_temporality_delta.out"
    },
    "metric_temporality_cumulative": {
      "envs": {
        "OTEL_METRIC_EXPORT_INTERVAL": "1000",
        "OTEL_EXPORTER_OTLP_METRICS_TEMPORALITY_PREFERENCE": "cumulative"
      },
      "args": "run -A main.ts metric_temporality.ts",
      "output": "metric_temporality_cumulative.out"
    },
    "propagators_api": {
      "args": "run -A main.ts propagators_api.ts",
      "output": "propagators_api.out"
    },
    "baggage_api": {
      "args": "run -A main.ts baggage_api.ts",
      "output": "baggage_api.out"
    },
    "trace_context_propagator": {
      "args": "run -A main.ts trace_context_propagator.ts",
      "output": "trace_context_propagator.out"
    },
    "cron": {
      "args": "run -A main.ts cron.ts",
      "output": "cron.out"
    },
    "cron_error": {
      "args": "run -A main.ts cron_error.ts",
      "output": "cron_error.out"
    },
    "http_server_status": {
      "args": "run -A main.ts http_server_status.ts",
      "output": "http_server_status.out"
    },
    "http_route": {
      "envs": {
        "OTEL_METRIC_EXPORT_INTERVAL": "1000"
      },
      "args": "run -A main.ts http_route.ts",
      "output": "http_route.out"
    },
    "array_attributes": {
      "args": "run -A main.ts array_attributes.ts",
      "output": "array_attributes.out"
    },
    "array_attributes_mixed": {
      "args": "run -A main.ts array_attributes_mixed.ts",
      "output": "array_attributes_mixed.out"
    },
    "reentrant_attributes": {
      "envs": {
        "OTEL_METRIC_EXPORT_INTERVAL": "1000",
        "OTEL_SPAN_ATTRIBUTE_COUNT_LIMIT": "1"
      },
      "args": "run -A main.ts reentrant_attributes.ts",
      "output": "reentrant_attributes.out"
    },
    "console_time": {
      "args": "run -A main.ts console_time.ts",
      "output": "console_time.out"
    },
    "log_exception": {
      "args": "run -A main.ts log_exception.ts",
      "output": "log_exception.out"
    },
    "http_serve_error_with_otel": {
      "args": "run -A main.ts http_serve_error_with_otel.ts",
      "output": "http_serve_error_with_otel.out"
    },
    "basic_grpc": {
      "args": "run -A -q main.ts basic.ts",
      "envs": {
        "OTEL_EXPORTER_OTLP_PROTOCOL": "grpc"
      },
      "output": "basic.out"
    },
    "metric_grpc": {
      "envs": {
        "OTEL_EXPORTER_OTLP_PROTOCOL": "grpc",
        "OTEL_METRIC_EXPORT_INTERVAL": "1000"
      },
      "args": "run -A -q main.ts metric.ts",
      "output": "metric.out"
    },
    "events_grpc": {
      "args": "run -A -q main.ts events.ts",
      "envs": {
        "OTEL_EXPORTER_OTLP_PROTOCOL": "grpc"
      },
      "output": "events.out"
    },
    "grpc_trailers": {
      "args": "run -A -q grpc_trailer_main.ts events.ts",
      "output": "events.out"
    },
    "grpc_trailers_error": {
      "args": "run -A -q grpc_trailer_main.ts events.ts",
      "envs": {
        "GRPC_TRAILER_STATUS": "14",
        "GRPC_TRAILER_MESSAGE": "UNAVAILABLE"
      },
      "output": "grpc_trailers_error.out"
    },
    "span_event_limit": {
      "args": "run -A main.ts span_event_limit.ts",
      "envs": {
        "OTEL_SPAN_EVENT_COUNT_LIMIT": "2"
      },
      "output": "span_event_limit.out"
    },
    "span_attribute_limit": {
      "args": "run -A main.ts span_attribute_limit.ts",
      "envs": {
        "OTEL_SPAN_ATTRIBUTE_COUNT_LIMIT": "2"
      },
      "output": "span_attribute_limit.out"
    },
    "span_attribute_value_length_limit": {
      "args": "run -A main.ts span_attribute_value_length_limit.ts",
      "envs": {
        "OTEL_ATTRIBUTE_VALUE_LENGTH_LIMIT": "5"
      },
      "output": "span_attribute_value_length_limit.out"
    },
    "traces_sampler_always_on": {
      "args": "run -A main.ts traces_sampler.ts",
      "envs": {
        "OTEL_TRACES_SAMPLER": "always_on"
      },
      "output": "traces_sampler_on.out"
    },
    "traces_sampler_always_off": {
      "args": "run -A main.ts traces_sampler.ts",
      "envs": {
        "OTEL_TRACES_SAMPLER": "always_off"
      },
      "output": "traces_sampler_off.out"
    },
    "traces_sampler_traceidratio_zero": {
      "args": "run -A main.ts traces_sampler.ts",
      "envs": {
        "OTEL_TRACES_SAMPLER": "traceidratio",
        "OTEL_TRACES_SAMPLER_ARG": "0"
      },
      "output": "traces_sampler_off.out"
    },
    "traces_sampler_parentbased_always_off": {
      "args": "run -A main.ts traces_sampler.ts",
      "envs": {
        "OTEL_TRACES_SAMPLER": "parentbased_always_off"
      },
      "output": "traces_sampler_off.out"
    }
  }
}
