{
  "tempDir": true,
  "steps": [{
    "args": "bump-version --workspace --config package.json patch",
    "output": "conflict.out",
    "exitCode": 1
  }, {
    "args": "bump-version --config package.json patch",
    "output": "patch.out"
  }, {
    "args": "bump-version -c package.json",
    "output": "after_pkg.out"
  }, {
    "args": "bump-version",
    "output": "after_deno.out"
  }]
}
