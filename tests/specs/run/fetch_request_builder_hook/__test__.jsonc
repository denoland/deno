{
  "tests": {
    "sets_headers": {
      "args": "run -A main.ts",
      "envs": {
        "X_DENO_FETCH_TOKEN": "test-fetch-token-123",
        "CDN_LOOP": "us-east-1.example.deno-cluster.net"
      },
      "output": "main.out"
    },
    "no_env": {
      "args": "run -A main_no_env.ts",
      "output": "main_no_env.out"
    }
  }
}
