{
  "tests": {
    "computed_no_read": {
      "args": "run --no-prompt computed.ts",
      "output": "no suggestion\n"
    },
    "computed_requested_read": {
      "args": "run --no-prompt --allow-read=./computed_target.js computed.ts",
      "output": "no suggestion\n"
    },
    "prepared_literal_dynamic": {
      "args": "run --no-prompt source/literal.ts",
      "output": "extension suggestion\ndirectory suggestion\n"
    },
    "root": {
      "args": "run computed_target.js",
      "output": "root.out",
      "exitCode": 1
    }
  }
}
