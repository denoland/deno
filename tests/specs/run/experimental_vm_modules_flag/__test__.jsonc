{
  // Regression for https://github.com/denoland/deno/issues/29917
  // --experimental-vm-modules is a Node.js flag that gates vm.Module; in Deno
  // vm.Module is always available so the flag is silently accepted.
  "tests": {
    "run_subcommand": {
      "args": "run --experimental-vm-modules main.js",
      "output": "main.out"
    },
    "top_level": {
      "args": "--experimental-vm-modules main.js",
      "output": "main.out"
    },
    "eval": {
      "args": "eval --experimental-vm-modules console.log(42)",
      "output": "42\n"
    }
  }
}
