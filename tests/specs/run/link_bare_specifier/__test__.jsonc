{
  "tempDir": true,
  "tests": {
    "bare_specifier_resolves": {
      "args": "run bare.ts",
      "output": "bare.out"
    },
    "jsr_specifier_resolves": {
      "args": "run jsr_prefix.ts",
      "output": "jsr_prefix.out"
    },
    "import_map_entry_resolves": {
      "args": "run --config=with_import_map.json import_map.ts",
      "output": "import_map.out"
    },
    "wrong_name_hints_full_name": {
      "args": "run wrong_name.ts",
      "output": "wrong_name.out",
      "exitCode": 1
    },
    "wrong_name_hints_full_name_check": {
      // ignored: the check path surfaces tsc's generic TS2882 instead of deno's
      // resolver hint suggesting the full name.
      // https://github.com/denoland/deno/issues/36085
      "ignore": true,
      "args": "check wrong_name.ts",
      "output": "wrong_name_check.out",
      "exitCode": 1
    }
  }
}
