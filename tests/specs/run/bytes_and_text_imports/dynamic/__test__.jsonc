{
  "tests": {
    "missing_permissions": {
      // Deny the non-analyzable imports so they stay read-denied under the
      // default cwd read confinement, keeping the test focused on the
      // permission requirement for dynamic bytes/text imports.
      "args": "run --deny-read=non_analyzable.txt,non_analyzable_utf8_bom.txt main.ts",
      "output": "main_missing_permissions.out",
      "exitCode": 1
    },
    "permissions": {
      "args": "run --allow-read=non_analyzable.txt,non_analyzable_utf8_bom.txt main.ts",
      "output": "main.out"
    }
  }
}
