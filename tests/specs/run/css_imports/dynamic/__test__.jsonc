{
  "tests": {
    "missing_permissions": {
      // Deny the non-analyzable import so it stays read-denied under the
      // default cwd read confinement, keeping the test focused on the
      // permission requirement for dynamic css imports.
      "args": "run --deny-read=other.css main.ts",
      "output": "main_missing_permissions.out",
      "exitCode": 1
    },
    "permissions": {
      "args": "run --allow-read=other.css main.ts",
      "output": "main.out"
    }
  }
}
