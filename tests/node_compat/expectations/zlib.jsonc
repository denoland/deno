    "parallel/test-zlib-flush-write-sync-interleaved.js": {},
    "parallel/test-zlib-flush.js": {},
    "parallel/test-zlib-from-concatenated-gzip.js": {},
    "parallel/test-zlib-from-gzip-with-trailing-garbage.js": {},
