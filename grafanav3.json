      "pluginVersion": "11.4.0",
      "targets": [
        {
          "expr": "{service_name=~\"$service_name\"} | scope_name = `deno.permission.access` | line_format `{{.deno_permission_outcome}} [{{.deno_permission_type}}] {{.deno_permission_value}}`",
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI}"
          }
        }
      ],
      "title": "Recent Permission Accesses",
      "type": "logs"
