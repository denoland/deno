      },
      "pluginVersion": "11.4.0",
      "targets": [
        {
          "expr": "sum by (deno_permission_type) (count_over_time({service_name=~\"$service_name\"} | scope_name = `deno.permission.access` [$interval]))",
          "legendFormat": "{{deno_permission_type}}",
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI}"
          }
        }
      ],
      "title": "Permission Accesses Over Time",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI}"
      },
