                "id": "displayName",
                "value": "Permission"
              },
              {
                "id": "custom.width",
                "value": 120
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "deno_permission_value"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Resource"
              },
              {
                "id": "custom.width",
                "value": 300
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Value #A"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Count"
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 8,
        "w": 16,
        "x": 8,
        "y": 9
      },
      "id": 3,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "fields": "",
          "reducer": [
            "sum"
          ],
          "show": false
        },
        "showHeader": true,
        "sortBy": [
          {
            "desc": true,
            "displayName": "Count"
          }
        ]
      },
      "pluginVersion": "11.4.0",
      "targets": [
        {
          "expr": "topk(10, sum by (deno_permission_type, deno_permission_value) (count_over_time({service_name=~\"$service_name\"} | scope_name = `deno.permission.access` [$__range])))",
          "instant": true,
          "legendFormat": "{{deno_permission_type}}: {{deno_permission_value}}",
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI}"
          }
        }
      ],
      "title": "Top Accessed Resources",
      "type": "table"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI}"
