From f413b0c2eb235df94ab598ed2092013d496d541d Mon Sep 17 00:00:00 2001
From: divybot <divybot@users.noreply.github.com>
Date: Fri, 15 May 2026 04:22:48 +0000
Subject: [PATCH] qjs_v8_compat patches: cfunc auto-prototype + cyclic-export
 TDZ placeholder

---
 quickjs.c | 51 +++++++++++++++++++++++++++++++++++++++++----------
 1 file changed, 41 insertions(+), 10 deletions(-)

diff --git a/quickjs.c b/quickjs.c
index 0a3abac..4d14b05 100644
--- a/quickjs.c
+++ b/quickjs.c
@@ -6115,6 +6115,11 @@ static int js_method_set_properties(JSContext *ctx, JSValue func_obj,
     return 0;
 }
 
+/* qjs_v8_compat: forward decl needed for the patch in JS_NewCFunction3. */
+static int JS_DefineAutoInitProperty(JSContext *ctx, JSValueConst this_obj,
+                                     JSAtom prop, JSAutoInitIDEnum id,
+                                     void *opaque, int flags);
+
 /* Note: at least 'length' arguments will be readable in 'argv' */
 /* `name` may be NULL, pure ASCII or UTF-8 encoded */
 JSValue JS_NewCFunction3(JSContext *ctx, JSCFunction *func,
@@ -6153,6 +6158,18 @@ JSValue JS_NewCFunction3(JSContext *ctx, JSCFunction *func,
     }
     js_function_set_properties(ctx, func_obj, name_atom, length);
     JS_FreeAtom(ctx, name_atom);
+    /* qjs_v8_compat patch: JS_CFUNC_generic_magic is the cproto used by
+       our deno_core op trampoline (FunctionTemplate). Real V8's
+       FunctionTemplate-built constructors auto-receive `.prototype`,
+       and deno_core's setUpAsyncStub writes
+       `tmpl_fn.prototype[opName] = fn`. Lazily attach a prototype slot
+       (mirrors the bytecode-function path further below). */
+    if (cproto == JS_CFUNC_generic_magic) {
+        JS_SetConstructorBit(ctx, func_obj, true);
+        JS_DefineAutoInitProperty(ctx, func_obj, JS_ATOM_prototype,
+                                  JS_AUTOINIT_ID_PROTOTYPE, NULL,
+                                  JS_PROP_WRITABLE);
+    }
     return func_obj;
 }
 
@@ -29820,17 +29837,31 @@ static JSValue js_build_module_ns(JSContext *ctx, JSModuleDef *m)
             {
                 JSVarRef *var_ref = en->u.var_ref;
                 if (!var_ref) {
-                    js_resolve_export_throw_error(ctx, JS_RESOLVE_RES_CIRCULAR,
-                                                  m, en->export_name);
-                    goto fail;
+                    /* qjs_v8_compat */
+                    char ebuf[64], mbuf[64];
+                    fprintf(stderr, "[qjs] cyclic-tdz '%s' in '%s'\n",
+                            JS_AtomGetStr(ctx, ebuf, sizeof(ebuf), en->export_name),
+                            JS_AtomGetStr(ctx, mbuf, sizeof(mbuf), m->module_name));
+                    var_ref = js_create_var_ref(ctx, true);
+                    if (!var_ref)
+                        goto fail;
+                    pr = add_property(ctx, p, en->export_name,
+                                      JS_PROP_ENUMERABLE | JS_PROP_WRITABLE |
+                                      JS_PROP_VARREF);
+                    if (!pr) {
+                        free_var_ref(ctx->rt, var_ref);
+                        goto fail;
+                    }
+                    pr->u.var_ref = var_ref;
+                } else {
+                    pr = add_property(ctx, p, en->export_name,
+                                      JS_PROP_ENUMERABLE | JS_PROP_WRITABLE |
+                                      JS_PROP_VARREF);
+                    if (!pr)
+                        goto fail;
+                    var_ref->header.ref_count++;
+                    pr->u.var_ref = var_ref;
                 }
-                pr = add_property(ctx, p, en->export_name,
-                                  JS_PROP_ENUMERABLE | JS_PROP_WRITABLE |
-                                  JS_PROP_VARREF);
-                if (!pr)
-                    goto fail;
-                var_ref->header.ref_count++;
-                pr->u.var_ref = var_ref;
             }
             break;
         case EXPORTED_NAME_NS:
