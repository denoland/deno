+  readLines(options: { encoding?: string } = {}): AsyncIterableIterator<string> {
+    const encoding = options.encoding ?? "utf8";
+    const decoder = new TextDecoder(encoding);
+    const fh = this;
+    const chunkSize = 64 * 1024; // 64KB
+    const temp = new Uint8Array(chunkSize);
+    let buffer = "";
+    let isReading = true;
+
+    return {
+      [Symbol.asyncIterator]() {
+        return this;
+      },
+      async next(): Promise<IteratorResult<string>> {
+        while (isReading) {
+          const { bytesRead } = await fh.read(temp, 0, chunkSize, null);
+          if (bytesRead === 0) {
+            isReading = false;
+            break;
+          }
+
+          buffer += decoder.decode(temp.subarray(0, bytesRead));
+
+          const newlineIndex = buffer.indexOf("\n");
+          if (newlineIndex !== -1) {
+            const line = buffer.slice(0, newlineIndex).replace(/\r$/, "");
+            buffer = buffer.slice(newlineIndex + 1);
+            return { value: line, done: false };
+          }
+        }
+
+        // Handle the last line if it exists
+        if (buffer.length > 0) {
+          const line = buffer;
+          buffer = "";
+          return { value: line, done: false };
+        }
+
+        return { value: undefined, done: true };
+      },
+    };
+  }
+
